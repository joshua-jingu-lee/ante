# E2E 테스트 러너 — Playwright + pytest
#
# Microsoft 공식 Playwright 이미지 사용 (Chromium 포함).
# 호스트에 브라우저 설치 불필요.

FROM mcr.microsoft.com/playwright/python:v1.52.0-noble

WORKDIR /app

# Python 패키지 설치 (e2e 의존성)
COPY pyproject.toml ./
COPY src/ src/
RUN pip install --no-cache-dir ".[e2e]"

# 테스트 코드 복사
COPY tests/ tests/

# 결과 디렉토리
RUN mkdir -p test-results

ENTRYPOINT ["pytest"]
CMD ["tests/e2e/", "-m", "e2e", "--tb=short", "-v"]
